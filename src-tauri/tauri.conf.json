{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KB Android Emulator",
  "version": "0.1.3",
  "identifier": "com.kb.androidemulator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KB Android Emulator Manager",
        "width": 1300,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
